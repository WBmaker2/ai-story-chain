# ============================================
# AI 이미지 생성 서비스 설정
# ============================================

# 1. Pollinations.ai (기본, 무료, API Key 불필요)
PROMPT_PREFIX=cute fairy tale illustration for elementary school children, bright pastel colors, scene:
POLLINATIONS_WIDTH=512
POLLINATIONS_HEIGHT=512

# 요청 제한(선택)
MAX_REQUEST_BYTES=8192
MAX_SENTENCE_CHARS=500

# 2. Hugging Face Inference API (fallback 옵션)
# 무료 Access Token 발급: https://huggingface.co/settings/tokens
# HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HUGGINGFACE_MODEL=runwayml/stable-diffusion-v1-5

# 로컬 실행일 때만 사용(선택)
APP_BASE_URL=http://127.0.0.1:4173
